{
  "name": "koda-theme-vscode",
  "displayName": "Koda Neovim Theme For Visual Studio Code",
  "description": "oskarnurm's Koda neovim theme ported to Visual Studio Code",
  "icon": "assets/icons/icon.png",
  "galleryBanner": {
    "color": "#101010",
    "theme": "dark"
  },
  "version": "1.0.0",
  "publisher": "davellen",
  "license": "MIT",
  "engines": {
    "vscode": "^1.90.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/daveleone/Koda-VS-Code"
  },
  "bugs": {
    "url": "https://github.com/daveleone/Koda-VS-Code/issues"
  },
  "homepage": "https://github.com/daveleone/Koda-VS-Code",
  "categories": [
    "Themes"
  ],
  "keywords": [
    "koda",
    "neovim",
    "theme",
    "dark"
  ],
  "contributes": {
    "themes": [
      {
        "label": "Koda Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/koda-dark-color-theme.json"
      },
      {
        "label": "Koda Glade",
        "uiTheme": "vs",
        "path": "./themes/koda-glade-color-theme.json"
      },
      {
        "label": "Koda Light",
        "uiTheme": "vs",
        "path": "./themes/koda-light-color-theme.json"
      },
      {
        "label": "Koda Moss",
        "uiTheme": "vs-dark",
        "path": "./themes/koda-moss-color-theme.json"
      }
    ]
  },
  "scripts": {
    "generate": "bun src/generate.ts"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@vscode/vsce": "^3.9.2",
    "typescript": "^5.0.0"
  }
}