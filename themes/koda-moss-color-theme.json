    "tokenColors": [
        {
            "scope": [
                "comment",
                "punctuation.definition.comment"
            ],
            "settings": {
                "foreground": "#707070",
                "fontStyle": "italic"
            }
        },
        {
            "scope": [
                "constant",
                "constant.language",
                "constant.numeric",
                "constant.numeric.integer",
                "constant.numeric.float",
                "constant.language.boolean",
                "support.constant",
                "variable.other.enummember"
            ],
            "settings": {
                "foreground": "#dfdf8e"
            }
        },
        {
            "scope": [
                "string",
                "string.quoted",
                "string.template",
                "string.regexp"
            ],
            "settings": {
                "foreground": "#95cb82"
            }
        },
        {
            "scope": [
                "constant.character",
                "constant.character.escape"
            ],
            "settings": {
                "foreground": "#dfdf8e"
            }
        },
        {
            "scope": [
                "variable",
                "variable.other",
                "variable.parameter",
                "variable.language",
                "identifier",
                "entity.name.variable",
                "variable.other.readwrite",
                "variable.other.property",
                "variable.object.property",
                "variable.member"
            ],
            "settings": {
                "foreground": "#cecece"
            }
        },
        {
            "scope": [
                "variable.other.readwrite.alias",
                "entity.name.namespace",
                "entity.name.import",
                "support.module",
                "support.type"
            ],
            "settings": {
                "foreground": "#999999"
            }
        },
        {
            "scope": [
                "entity.name.function",
                "support.function",
                "variable.function",
                "meta.function-call",
                "support.function.builtin"
            ],
            "settings": {
                "foreground": "#71ade7"
            }
        },
        {
            "scope": [
                "keyword",
                "keyword.control",
                "storage",
                "storage.modifier",
                "meta.preprocessor",
                "keyword.control.import",
                "keyword.control.from"
            ],
            "settings": {
                "foreground": "#999999"
            }
        },
        {
            "scope": [
                "keyword.operator",
                "punctuation.separator",
                "punctuation.accessor"
            ],
            "settings": {
                "foreground": "#708b8d"
            }
        },
        {
            "scope": [
                "entity.name.type",
                "entity.name.class",
                "entity.name.interface",
                "entity.name.struct",
                "support.type"
            ],
            "settings": {
                "foreground": "#708b8d"
            }
        },
        {
            "scope": [
                "storage.type",
                "storage.type.class",
                "storage.type.interface",
                "storage.type.struct",
                "storage.class",
                "storage.modifier"
            ],
            "settings": {
                "foreground": "#999999"
            }
        },
        {
            "scope": [
                "entity.name.tag"
            ],
            "settings": {
                "foreground": "#cecece"
            }
        },
        {
            "scope": [
                "invalid"
            ],
            "settings": {
                "foreground": "#d2322d"
            }
        },
        {
            "scope": [
                "markup.inserted"
            ],
            "settings": {
                "foreground": "#6abf40"
            }
        },
        {
            "scope": [
                "markup.changed"
            ],
            "settings": {
                "foreground": "#ec8013"
            }
        },
        {
            "scope": [
                "markup.deleted"
            ],
            "settings": {
                "foreground": "#d2322d"
            }
        },
        {
            "scope": [
                "markup.heading"
            ],
            "settings": {
                "foreground": "#71ade7",
                "fontStyle": "bold"
            }
        },
        {
            "scope": [
                "markup.italic"
            ],
            "settings": {
                "fontStyle": "italic"
            }
        },
        {
            "scope": [
                "markup.bold"
            ],
            "settings": {
                "fontStyle": "bold"
            }
        },
        {
            "scope": [
                "markup.raw"
            ],
            "settings": {
                "foreground": "#dfdf8e"
            }
        },
        {
            "scope": [
                "markup.link.url"
            ],
            "settings": {
                "foreground": "#8ebeec",
                "fontStyle": "underline"
            }
        },
        {
            "scope": [
                "variable.other.constant.property",
                "variable.other.constant.property.ts"
            ],
            "settings": {
                "foreground": "#999999"
            }
        }
    ],
    "semanticTokenColors": {
        "variable": {
            "foreground": "#cecece"
        },
        "variable.readonly": {
            "foreground": "#cecece"
        },
        "variable.defaultLibrary": {
            "foreground": "#dfdf8e"
        },
        "parameter": {
            "foreground": "#cecece"
        },
        "property": {
            "foreground": "#cecece"
        },
        "property.readonly": {
            "foreground": "#cecece"
        },
        "namespace": {
            "foreground": "#cecece"
        },
        "namespace.defaultLibrary": {
            "foreground": "#cecece"
        },
        "function": {
            "foreground": "#71ade7"
        },
        "method": {
            "foreground": "#71ade7"
        },
        "type": {
            "foreground": "#708b8d"
        },
        "class": {
            "foreground": "#708b8d"
        },
        "interface": {
            "foreground": "#708b8d"
        },
        "struct": {
            "foreground": "#708b8d"
        },
        "keyword": {
            "foreground": "#999999"
        },
        "string": {
            "foreground": "#95cb82"
        },
        "number": {
            "foreground": "#dfdf8e"
        },
        "operator": {
            "foreground": "#708b8d"
        },
        "constant": {
            "foreground": "#dfdf8e"
        },
        "variable.constant": {
            "foreground": "#dfdf8e"
        },
        "variable.defaultLibrary.constant": {
            "foreground": "#dfdf8e"
        },
        "enumMember": {
            "foreground": "#dfdf8e"
        }
    }
}