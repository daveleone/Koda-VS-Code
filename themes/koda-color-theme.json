            ],
            "settings": {
                "foreground": "#777777"
            }
        },
        {
            "scope": [
                "meta.preprocessor"
            ],
            "settings": {
                "foreground": "#b0b0b0"
            }
        },
        {
            "scope": [
                "entity.name.tag"
            ],
            "settings": {
                "foreground": "#b0b0b0"
            }
        },
        {
            "scope": [
                "invalid"
            ],
            "settings": {
                "foreground": "#ff7676"
            }
