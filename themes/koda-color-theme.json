                "foreground": "#50585d",
                "fontStyle": "italic"
            }
        },
        {
            "scope": [
                "constant",
                "constant.language"
            ],
            "settings": {
                "foreground": "#d9ba73"
            }
        },
        {
            "scope": [
                "string",
                "string.quoted"
            ],
            "settings": {
                "foreground": "#ffffff"
            }
        },
        {
            "scope": [
                "constant.character"
            ],
            "settings": {
                "foreground": "#ffffff"
            }
        },
        {
            "scope": [
                "constant.numeric"
            ],
            "settings": {
                "foreground": "#d9ba73"
            }
        },
        {
            "scope": [
                "constant.language.boolean"
            ],
            "settings": {
                "foreground": "#d9ba73"
            }
        },
        {
            "scope": [
                "variable",
                "identifier"
            ],
            "settings": {
                "foreground": "#ffffff"
            }
        },
        {
            "scope": [
                "entity.name.function",
                "support.function"
            ],
            "settings": {
                "foreground": "#ffffff"
            }
        },
        {
            "scope": [
                "keyword",
                "storage"
            ],
            "settings": {
